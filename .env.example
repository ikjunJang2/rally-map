# 복사해서 .env 로 저장하고 값을 채우세요. .env는 절대 커밋하지 마세요.
RALLY_ADMIN_USER=admin
RALLY_ADMIN_PASS=강한-비밀번호로-교체
RALLY_TOKEN_SECRET=긴-무작위-문자열로-교체
WEB_PORT=80

# 선택: 유튜브 라이브 자동 수집 (console.cloud.google.com → YouTube Data API v3 키)
YOUTUBE_API_KEY=
# 선택: 주변 교통 CCTV 실시간 보기 (its.go.kr/opendata → 오픈API 키)
ITS_API_KEY=
